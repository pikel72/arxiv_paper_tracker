# ArXiv论文追踪与分析系统 - 环境变量配置示例
# 复制此文件为 .env 并填入您的实际配置

# ==================== AI模型API密钥配置 ====================
# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# 智谱AI (GLM)
GLM_API_KEY=your-glm-api-key

# 通义千问 (Qwen)
QWEN_API_KEY=sk-your-qwen-api-key

# 豆包
DOUBAO_API_KEY=your-doubao-api-key

# Kimi
KIMI_API_KEY=your-kimi-api-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# SiliconFlow
SILICONFLOW_API_KEY=your-siliconflow-api-key

# NVIDIA NIM
# 兼容变量名: NVIDIA_API_KEY
NVIDIA_NIM_API_KEY=your-nvidia-nim-api-key
# 兼容变量名: NVIDIA_API_BASE
NVIDIA_NIM_API_BASE=https://integrate.api.nvidia.com/v1

# 自定义API
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_API_BASE=https://your-custom-api.com/v1

# ==================== AI模型选择配置 ====================
# 支持: deepseek, openai, glm, qwen, doubao, kimi, openrouter, siliconflow, nvidia_nim, custom
# 默认值: qwen
AI_PROVIDER=qwen

# 模型名称，根据提供商不同而不同
# 普通模型:
#   DeepSeek: deepseek-chat, deepseek-coder
#   OpenAI: gpt-4, gpt-3.5-turbo
#   GLM: glm-4, glm-3-turbo
#   Qwen: qwen-plus, qwen-turbo, qwen-max
# 推理模型（用于 --thinking 模式）:
#   DeepSeek: deepseek-reasoner
#   Qwen: qwq-plus
#   OpenAI: o1
#   Kimi: kimi-k2-thinking
# 默认值: qwen-turbo
AI_MODEL=qwen-turbo

# 注意：如果使用 qwen/... 这类前缀路由模型名，请显式匹配服务商：
#   NVIDIA NIM: AI_PROVIDER=nvidia_nim + NVIDIA_NIM_API_KEY（或 NVIDIA_API_KEY）
#   OpenRouter: AI_PROVIDER=openrouter + OPENROUTER_API_KEY
#   DashScope 直连建议使用 qwen-plus / qwen-turbo 这类模型名 + QWEN_API_KEY

# 可选：默认开启或关闭完整分析的思考模式（on/off）
ANALYSIS_THINKING_MODE=off

# 可选：--thinking 模式下使用的模型覆盖
ANALYSIS_THINKING_MODEL=

# 可选：支持预算/努力等级的提供商可使用
ANALYSIS_THINKING_BUDGET=
ANALYSIS_THINKING_EFFORT=

# 可选：完整分析完成后，再用一个专门的文本清洗模型做 block-level cleanup
ANALYSIS_CLEANUP_ENABLED=off
ANALYSIS_CLEANUP_PROVIDER=
ANALYSIS_CLEANUP_MODEL=
ANALYSIS_CLEANUP_THINKING_MODE=off

# ==================== 邮件服务器配置 ====================
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your_qq@qq.com
SMTP_PASSWORD=your_qq_authorization_code
EMAIL_FROM=your_qq@qq.com
# 支持多个收件人，用逗号分隔
EMAIL_TO=recipient@email.com,recipient2@email.com

# ==================== ArXiv搜索配置 ====================
# 论文类别，用逗号分隔
# 常见类别: math.AP(偏微分方程), cs.AI(人工智能), cs.LG(机器学习)
ARXIV_CATEGORIES=math.AP

# 每次获取的最大论文数量
MAX_PAPERS=50

# 搜索最近几天的论文
SEARCH_DAYS=5

# ==================== 主题配置 ====================
# 重点关注主题（用 | 分隔），相关论文会进行完整PDF分析
PRIORITY_TOPICS=流体力学中偏微分方程的数学理论|Navier-Stokes方程|Euler方程|Prandtl方程|湍流|涡度

# 了解领域主题（用 | 分隔），相关论文只翻译摘要
SECONDARY_TOPICS=色散偏微分方程的数学理论|双曲偏微分方程的数学理论|调和分析|极大算子|椭圆偏微分方程|抛物偏微分方程

# ==================== 性能配置 ====================
# 并行处理的最大线程数（建议 3-10）
MAX_THREADS=5

# API调用延时配置（秒）
PRIORITY_ANALYSIS_DELAY=3
SECONDARY_ANALYSIS_DELAY=2

# ==================== 邮件配置 ====================
EMAIL_SUBJECT_PREFIX="arXiv 论文分析报告"

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=arxiv_tracker.log
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
